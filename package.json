{
  "name": "simplifica-3d",
  "version": "0.1.0",
  "private": true,
  "description": "Simplifica 3D para gestao de pedidos, caixa e impressao 3D.",
  "scripts": {
    "build:web": "node scripts/prepare-web.js",
    "supabase:help": "supabase --help",
    "supabase:login": "supabase login",
    "supabase:link": "supabase link --project-ref qsufnnivlgdidmjuaprb",
    "supabase:advisors": "supabase db advisors --linked --type all --level warn",
    "supabase:lint": "supabase db lint --linked",
    "supabase:migrations": "supabase migration list --linked",
    "supabase:test:db": "supabase test db --linked",
    "supabase:test:rest": "node scripts/test-supabase-rest.js",
    "supabase:test:telemetry": "node scripts/test-telemetry-rest.js",
    "supabase:test:migrations": "node scripts/check-supabase-migrations.js",
    "android:add": "npm run build:web && cap add android",
    "android:sync": "npm run build:web && cap sync android",
    "android:open": "npm run android:sync && cap open android",
    "android:apk": "npm run android:sync && cd android && gradlew.bat assembleDebug && cd .. && npm run android:apk:copy",
    "android:apk:copy": "node scripts/copy-android-apk.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "supabase": "^2.98.0"
  }
}
